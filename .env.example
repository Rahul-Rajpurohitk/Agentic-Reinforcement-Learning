# LLM API — supports OpenAI, HuggingFace, or any OpenAI-compatible endpoint
# The inference script auto-detects: tries OpenAI API first, falls back to HF InferenceClient
OPENAI_API_KEY=your_openai_api_key_here
API_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-4o

# HuggingFace (used for deployment + inference fallback)
HF_TOKEN=your_huggingface_token_here

# Environment Server
ENV_URL=http://localhost:8000
